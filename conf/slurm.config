/*
========================================================================================
    SLURM EXECUTOR CONFIGURATION
========================================================================================
    RCSI HPC - SLURM-specific process and executor settings.

    CPU BUDGET (30-CPU hard cap):
      Head job (this script)  :  1 CPU
      Per-worker job          :  1 CPU  (EH v5 is single-threaded)
      Concurrent workers      : 25      (queueSize below)
      Peak total              : 26 CPUs ≤ 30 cap ✔

    MEMORY BUDGET (per worker):
      process_low / process_single / process_aggregate → 2–8 GB
      process_medium (EH)                              → 4 GB base, retry bumps via base.config

    NOTE: base.config defines resource values via check_max().
          slurm.config only sets SLURM-specific executor and clusterOptions.
          Do not redefine cpus/memory here - let base.config handle that.
----------------------------------------------------------------------------------------
*/

process {

    // =========================================================================
    // SLURM CLUSTER OPTIONS - applied per label
    // account is optional - only added if params.slurm_account is set
    // =========================================================================

    withLabel: 'process_low' {
        queue          = params.slurm_partition
        clusterOptions = {
            def opts = "--ntasks=1 --nodes=1 --mail-type=FAIL"
            params.slurm_account ? "${opts} --account=${params.slurm_account}" : opts
        }
    }

    withLabel: 'process_medium' {
        queue          = params.slurm_partition
        clusterOptions = {
            def opts = "--ntasks=1 --nodes=1 --mail-type=FAIL"
            params.slurm_account ? "${opts} --account=${params.slurm_account}" : opts
        }
    }

    withLabel: 'process_single' {
        queue          = params.slurm_partition
        clusterOptions = {
            def opts = "--ntasks=1 --nodes=1 --mail-type=FAIL"
            params.slurm_account ? "${opts} --account=${params.slurm_account}" : opts
        }
    }

    withLabel: 'process_aggregate' {
        queue          = params.slurm_partition
        clusterOptions = {
            def opts = "--ntasks=1 --nodes=1 --mail-type=FAIL"
            params.slurm_account ? "${opts} --account=${params.slurm_account}" : opts
        }
    }
}

// ============================================================================
// EXECUTOR SETTINGS
// ============================================================================

executor {
    name = 'slurm'

    // 25 concurrent jobs × 1 CPU + 1 head = 26 total ≤ 30 cap
    queueSize = params.slurm_queue_size

    // How often Nextflow polls SLURM for job completion
    pollInterval = '30 sec'

    // Throttle job submission - polite to the SLURM scheduler
    submitRateLimit = '10 / 1 min'

    // Log executor status periodically (helps diagnose stalls)
    dumpInterval = '5 min'
}
