/*
========================================================================================
    LOCAL EXECUTOR CONFIGURATION
========================================================================================
    For interactive testing on login node or local workstation.
    Singularity must be available and autoMounts enabled.
    Not for production cohort runs - use slurm profile instead.
----------------------------------------------------------------------------------------
*/

process {
    executor = 'local'

    withLabel: 'process_low' {
        cpus   = 1
        memory = '4 GB'
        time   = '2h'
    }

    withLabel: 'process_medium' {
        cpus   = 1
        memory = '8 GB'
        time   = '48h'
    }

    withLabel: 'process_single' {
        cpus   = 1
        memory = '2 GB'
        time   = '1h'
    }

    withLabel: 'process_aggregate' {
        cpus   = 1
        memory = '8 GB'
        time   = '4h'
    }
}

// Limit concurrency on login node - be a good citizen
executor {
    name      = 'local'
    cpus      = 4
    memory    = '16 GB'
    queueSize = 4
}
