/*
========================================================================================
    TEST PROFILE CONFIGURATION
========================================================================================
    Minimal parameter overrides for pipeline syntax/dry-run testing.
    Use with: nextflow run main.nf -profile test -stub
    
    NOTE: This profile does not provide real input files.
    It only overrides resource limits to allow fast syntax validation.
    For a real test run use -profile slurm with actual BAM/PED inputs.
----------------------------------------------------------------------------------------
*/

params {
    // Resource caps - small for test/CI
    max_cpus   = 2
    max_memory = '8.GB'
    max_time   = '2.h'

    // Reduce concurrency
    slurm_queue_size = 2
}
