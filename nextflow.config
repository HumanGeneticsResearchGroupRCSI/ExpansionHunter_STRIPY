/*
========================================================================================
    EXPANSIONHUNTER REPEAT EXPANSION DETECTION PIPELINE v1.0
========================================================================================
    PED-driven repeat expansion calling with ExpansionHunter v5
----------------------------------------------------------------------------------------
*/

params {

    // =========================================================================
    // INPUT/OUTPUT
    // =========================================================================
    ped                         = null
    bam_dir                     = null
    outdir                      = './results'
    batch_name                  = 'expansionhunter'

    // =========================================================================
    // REFERENCE GENOME
    // =========================================================================
    genome                      = 'GRCh38'
    fasta                       = null
    fasta_fai                   = null

    // =========================================================================
    // EXPANSIONHUNTER CONFIGURATION
    // =========================================================================
    variant_catalog             = null
    analysis_mode               = 'seeking'          // 'seeking' (hybrid mini-BAM) | 'streaming' (no realigned BAM)
    bam_suffix                  = '.md.bam'
    regions_bed                 = null               // BED file of padded repeat loci (generated by generate_regions_bed.py)
                                                     // Required for hybrid seeking mode (samtools extract → EH seeking)
                                                     // Generate once: python3 scripts/generate_regions_bed.py --catalog <json> --output repeat_regions.bed

    // =========================================================================
    // RESOURCE LIMITS
    // =========================================================================
    max_cpus                    = 28
    max_memory                  = 128.GB
    max_time                    = 48.h

    // =========================================================================
    // PER-TOOL CPU ALLOCATION
    // =========================================================================
    samtools_cpus               = 1
    expansionhunter_cpus        = 1                  // EH v5 is single-threaded
    manifest_cpus               = 1

    // =========================================================================
    // PER-TOOL MEMORY ALLOCATION
    // =========================================================================
    samtools_memory             = 4.GB
    expansionhunter_memory      = 4.GB               // WES streaming mode
    manifest_memory             = 2.GB

    // =========================================================================
    // STORAGE CONFIGURATION
    // =========================================================================
    scratch_dir                 = '/local/scratch'

    // =========================================================================
    // SLURM CONFIGURATION
    // =========================================================================
    slurm_account               = null
    slurm_partition             = 'ProdQ'
    slurm_queue_size            = 25                 // 25 concurrent jobs = 26 CPUs total

    // =========================================================================
    // PIPELINE OPTIONS
    // =========================================================================
    help                        = false
    publish_dir_mode            = 'copy'

    // =========================================================================
    // STRIPY POST-PROCESSING
    // =========================================================================
    // Locus reference - bootstrap once via fetch_stripy_locus_ref.py
    stripy_locus_ref            = '/path/to/reference/stripy_locus_reference.json'

    // HPO annotation - genes_to_phenotype.txt from HPO
    hpo_file                    = '/path/to/resources/hpo_genes_to_phenotype.txt'

    // HPO disease filter - project-specific term list
    // Default: epilepsy. Override per project: --hpo_filter_file /path/to/hpo_renal_terms.txt
    hpo_filter_file             = null

    // Cohort identifier used in output filenames
    cohort_id                   = 'LH_WES'


    // Per-tool resource allocation for post-processing
    stripy_annotate_cpus        = 1
    stripy_annotate_memory      = 2.GB
    stripy_report_cpus          = 1
    stripy_report_memory        = 4.GB
    stripy_aggregate_cpus       = 1
    stripy_aggregate_memory     = 8.GB
}

// Container paths
params.singularity_image_dir = '/home/data/human_genetics/ONE4ALL/Docker_Images'

params.containers = [
    samtools:         "${params.singularity_image_dir}/samtools_1.23.sif",
    expansionhunter:  "${params.singularity_image_dir}/expansionhunter.sif",
    python:           "${params.singularity_image_dir}/python_openpyxl.sif"
]

profiles {
    slurm {
        process.executor = 'slurm'
        singularity.enabled = true
        singularity.runOptions = '--bind /home/data:/home/data --bind /local/scratch:/local/scratch'
        singularity.cacheDir = "${HOME}/.singularity/cache"
        docker.enabled = false
        includeConfig 'conf/slurm.config'
    }

    local {
        process.executor = 'local'
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        includeConfig 'conf/local.config'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

includeConfig 'conf/base.config'


// ── Execution reports (all timestamped via NF built-in) ───────
def ts = new java.util.Date().format('yyyyMMdd_HHmmss')

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline_${ts}.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report_${ts}.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/_${ts}trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem'
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag_${ts}.svg"
    overwrite = true
}

manifest {
    name            = 'expansionhunter-pipeline'
    author          = 'Deepak Bharti'
    description     = 'PED-driven repeat expansion detection with ExpansionHunter v5'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=25.04.0'
    version         = '2.0.0'
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Invalid max_memory, using default: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Invalid max_time, using default: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "WARNING: Invalid max_cpus, using default: $obj"
            return obj
        }
    }
}

cleanup = true
